#!/usr/bin/expect -f
set timeout 60
set env_home $env(HOME)

spawn ${env_home}/tizen-studio/tools/ide/bin/tizen package -t wgt -s StreamVault -- [pwd]/dist/.buildResult

expect {
    "Author password:" { send "$env(CERT_AUTHOR_PASSWORD)\r"; exp_continue }
    "Yes: (Y), No: (N) ?" { send "Y\r"; exp_continue }
    eof
}

lassign [wait] pid spawnid os_error value
exit $value
